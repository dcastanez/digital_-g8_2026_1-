digraph "DIV" {
label="DIV";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="DEN", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="NUM", color="black", fontcolor="black" ];
n3 [ shape=octagon, label="R", color="black", fontcolor="black" ];
n4 [ shape=octagon, label="clk", color="black", fontcolor="black" ];
n5 [ shape=octagon, label="done", color="black", fontcolor="black" ];
n6 [ shape=octagon, label="init", color="black", fontcolor="black" ];
n7 [ shape=octagon, label="rst", color="black", fontcolor="black" ];
n8 [ shape=diamond, label="w_DEN", color="black", fontcolor="black" ];
n9 [ shape=diamond, label="w_DP", color="black", fontcolor="black" ];
n10 [ shape=diamond, label="w_ac", color="black", fontcolor="black" ];
n11 [ shape=diamond, label="w_de", color="black", fontcolor="black" ];
n12 [ shape=diamond, label="w_rs", color="black", fontcolor="black" ];
c15 [ shape=record, label="{{<p3> R|<p13> ac|<p4> clk|<p14> rs}|acc0\nacc|{}}",  ];
c17 [ shape=record, label="{{<p1> DEN|<p16> c2}|comp20\ncomp2|{}}",  ];
c20 [ shape=record, label="{{<p18> DP|<p13> ac|<p4> clk|<p19> de|<p5> done|<p6> init|<p14> rs|<p7> rst}|control_DIV0\ncontrol_DIV|{}}",  ];
x0 [ shape=record, style=rounded, label="<s0> 15:15 - 0:0 ", color="black", fontcolor="black" ];
x0:e -> c20:p18:w [arrowhead=odiamond, arrowtail=odiamond, dir=both, color="black", fontcolor="black", label=""];
c21 [ shape=record, label="{{<p18> DP|<p2> NUM|<p16> c2|<p4> clk|<p19> de|<p14> rs}|dec0\ndec|{}}",  ];
n1:e -> c17:p1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n10:e -> c15:p13:w [color="black", fontcolor="black", label=""];
n10:e -> c20:p13:w [color="black", fontcolor="black", label=""];
n11:e -> c20:p19:w [color="black", fontcolor="black", label=""];
n11:e -> c21:p19:w [color="black", fontcolor="black", label=""];
n12:e -> c15:p14:w [color="black", fontcolor="black", label=""];
n12:e -> c20:p14:w [color="black", fontcolor="black", label=""];
n12:e -> c21:p14:w [color="black", fontcolor="black", label=""];
n2:e -> c21:p2:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n3:e -> c15:p3:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n4:e -> c15:p4:w [color="black", fontcolor="black", label=""];
n4:e -> c20:p4:w [color="black", fontcolor="black", label=""];
n4:e -> c21:p4:w [color="black", fontcolor="black", label=""];
n5:e -> c20:p5:w [color="black", fontcolor="black", label=""];
n6:e -> c20:p6:w [color="black", fontcolor="black", label=""];
n7:e -> c20:p7:w [color="black", fontcolor="black", label=""];
n8:e -> c17:p16:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n8:e -> c21:p16:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n9:e -> c21:p18:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n9:e -> x0:s0:w [color="black", fontcolor="black", label=""];
}
